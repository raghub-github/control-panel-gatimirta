{
  "name": "dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbopack": "next dev",
    "dev:webpack": "next dev --webpack",
    "clean": "node -e \"const fs=require('fs');const o={recursive:true,force:true,maxRetries:8,retryDelay:150};try{fs.rmSync('.next',o)}catch(e){}try{fs.rmSync('node_modules/.cache',o)}catch(e){}\"",
    "dev:clean": "npm run clean && next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test:db": "tsx scripts/test-db-connection.ts",
    "migrate": "tsx scripts/run-migration.ts",
    "migrate:owner": "tsx scripts/run-owner-full-name-migration.ts",
    "verify-migration": "tsx scripts/verify-migration.ts"
  },
